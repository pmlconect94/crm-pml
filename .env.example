# Credenciales del frontend (Supabase). Copia este archivo a .env.local y llena
# los valores. En Vercel se configuran como Environment Variables (SOLO estas 2).
# Valores: Supabase Dashboard -> proyecto crm-pml -> Settings -> API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Llave de SERVICIO — SOLO para los scripts locales de scripts/ (la RLS bloquea
# la anon key). NUNCA la pongas en Vercel ni en el frontend: no lleva prefijo
# VITE_, así que Vite no la incluye en el bundle. Dashboard -> Settings -> API.
SUPABASE_SERVICE_ROLE_KEY=
